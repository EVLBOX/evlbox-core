#!/usr/bin/env bash
#
# evlbox — CLI tool for EVLBOX Stacks
# Installed to /usr/local/bin/evlbox by the core installer.
#
# Thin wrapper: dispatches subcommands to the right scripts
# and provides consistent output formatting + branding.
#
# Contract: the active stack lives at /opt/evlbox/stack/ and provides
# compose.yml, setup.sh, and backup.sh. This CLI doesn't need to know
# which stack is installed — it just calls what's there.
#
# Multi-compose support: some stacks include upstream projects (e.g., Stoat)
# that run as separate compose projects. If /opt/evlbox/stack/.compose-projects
# exists, each line is an absolute path to an additional compose.yml.
# The CLI iterates over ALL compose projects for status, update, restart, logs.

set -euo pipefail

EVLBOX_VERSION="0.1.0"
STACK_DIR="${EVLBOX_STACK_DIR:-/opt/evlbox/stack}"
BACKUP_DIR="${EVLBOX_BACKUP_DIR:-/opt/evlbox/backups}"
COMPOSE_FILE="${STACK_DIR}/compose.yml"

# ──────────────────────────────────────────
# Brand colors (hex — used by gum)
# ──────────────────────────────────────────
BRAND_CYAN="#00d4ff"
BRAND_GREEN="#00e676"
BRAND_RED="#ff5252"
BRAND_AMBER="#ffab40"

# ──────────────────────────────────────────
# ANSI fallback colors
# ──────────────────────────────────────────
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ──────────────────────────────────────────
# Detect gum
# ──────────────────────────────────────────
HAS_GUM=false
command -v gum &>/dev/null && HAS_GUM=true

# ──────────────────────────────────────────
# Output helpers
# ──────────────────────────────────────────

print_banner() {
    if $HAS_GUM; then
        gum style \
            --border double \
            --border-foreground "$BRAND_CYAN" \
            --foreground "$BRAND_CYAN" \
            --bold \
            --padding "0 3" \
            --margin "1 0" \
            "EVLBOX CLI  v${EVLBOX_VERSION}"
    else
        echo ""
        echo -e "${CYAN}${BOLD}  ╔═══════════════════════════════╗${NC}"
        echo -e "${CYAN}${BOLD}  ║        EVLBOX  CLI            ║${NC}"
        echo -e "${CYAN}${BOLD}  ╚═══════════════════════════════╝${NC}"
        echo ""
    fi
}

info()  { echo -e "  ${CYAN}[evlbox]${NC} $*"; }
ok()    { echo -e "  ${GREEN}[evlbox]${NC} $*"; }
warn()  { echo -e "  ${YELLOW}[evlbox]${NC} $*"; }
err()   { echo -e "  ${RED}[evlbox]${NC} $*" >&2; }

# Section header
header() {
    if $HAS_GUM; then
        echo ""
        gum style --foreground "$BRAND_CYAN" --bold -- "$1"
    else
        echo ""
        echo -e "  ${CYAN}${BOLD}$1${NC}"
    fi
}

# Confirmation prompt (returns 0=yes, 1=no)
confirm() {
    local msg="$1"
    if $HAS_GUM; then
        gum confirm \
            --prompt.foreground "$BRAND_AMBER" \
            --selected.background "$BRAND_CYAN" \
            "$msg"
    else
        warn "$msg"
        read -rp "  Type 'yes' to confirm: " answer
        [[ "$answer" == "yes" ]]
    fi
}

# ──────────────────────────────────────────
# Guard helpers
# ──────────────────────────────────────────

require_stack() {
    if [[ ! -d "$STACK_DIR" ]] || [[ ! -f "$COMPOSE_FILE" ]]; then
        err "No stack installed yet."
        err "EVLBOX Core is ready, but no stack has been deployed to ${STACK_DIR}/"
        echo ""
        echo -e "  ${DIM}If you're setting up a new server, your stack's provisioner"
        echo -e "  will install its files here automatically.${NC}"
        exit 1
    fi
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        err "This command requires root. Try: sudo evlbox ${ORIGINAL_ARGS[*]:-}"
        exit 1
    fi
}

require_file() {
    if [[ ! -f "$1" ]]; then
        err "Required file not found: $1"
        exit 1
    fi
}

require_docker() {
    if ! docker info &>/dev/null; then
        err "Docker is not running. Start it with: sudo systemctl start docker"
        exit 1
    fi
}

# ──────────────────────────────────────────
# Multi-compose project support
# ──────────────────────────────────────────
# Returns an array of compose file paths. The stack's own compose.yml
# is always first. Additional projects listed in .compose-projects follow.

COMPOSE_PROJECTS=()

load_compose_projects() {
    COMPOSE_PROJECTS=("$COMPOSE_FILE")
    local index_file="${STACK_DIR}/.compose-projects"
    if [[ -f "$index_file" ]]; then
        while IFS= read -r line; do
            # Skip comments and blank lines
            [[ -z "$line" || "$line" == \#* ]] && continue
            if [[ -f "$line" ]]; then
                COMPOSE_PROJECTS+=("$line")
            else
                warn "Compose project not found (skipping): $line"
            fi
        done < "$index_file"
    fi
}

# Run a docker compose command against ALL compose projects
compose_all() {
    local cmd="$1"; shift
    for cf in "${COMPOSE_PROJECTS[@]}"; do
        local project_dir
        project_dir=$(dirname "$cf")
        local project_name
        project_name=$(basename "$project_dir")
        info "${project_name}:"
        docker compose -f "$cf" "$cmd" "$@" 2>/dev/null || true
    done
}

# ──────────────────────────────────────────
# Subcommands
# ──────────────────────────────────────────

cmd_status() {
    require_stack
    require_file "$COMPOSE_FILE"
    require_docker
    load_compose_projects

    print_banner

    # -- Services (all compose projects) --
    header "Services"
    for cf in "${COMPOSE_PROJECTS[@]}"; do
        local project_name
        project_name=$(basename "$(dirname "$cf")")
        echo -e "  ${DIM}── ${project_name} ──${NC}"
        docker compose -f "$cf" ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || {
            warn "Could not read status for ${project_name}."
        }
    done

    # -- System --
    header "System"

    # Disk
    local disk_pct disk_used disk_total
    read -r disk_pct disk_used disk_total < <(df -h / | awk 'NR==2 {gsub(/%/,"",$5); print $5, $3, $2}')
    local disk_color="${GREEN}"
    (( disk_pct > 80 )) && disk_color="${RED}"
    (( disk_pct > 60 && disk_pct <= 80 )) && disk_color="${YELLOW}"
    echo -e "  Disk:   ${disk_color}${disk_pct}%${NC} used (${disk_used} of ${disk_total})"

    # Memory
    local mem_used mem_total
    read -r mem_used mem_total < <(free -h | awk 'NR==2 {print $3, $2}')
    echo -e "  Memory: ${mem_used} / ${mem_total}"

    # Uptime
    local up
    up=$(uptime -p 2>/dev/null | sed 's/^up //' || echo "unknown")
    echo -e "  Uptime: ${up}"

    # -- Backups --
    header "Backups"
    if [[ -d "$BACKUP_DIR" ]]; then
        local latest
        latest=$(find "$BACKUP_DIR" -maxdepth 1 -name "*.tar.gz" -printf '%T@ %p\n' 2>/dev/null \
            | sort -rn | head -1 | cut -d' ' -f2-)
        if [[ -n "$latest" ]]; then
            local backup_date backup_size backup_count
            backup_date=$(stat -c %y "$latest" 2>/dev/null | cut -d'.' -f1)
            backup_size=$(du -h "$latest" | cut -f1)
            backup_count=$(find "$BACKUP_DIR" -maxdepth 1 -name "*.tar.gz" 2>/dev/null | wc -l)
            ok "Latest: ${backup_date} (${backup_size})"
            info "${backup_count} snapshot(s) total"
        else
            warn "No backups yet. Run 'evlbox backup' to create one."
        fi
    else
        warn "Backup directory missing."
    fi

    # -- Updates --
    header "Updates"
    if docker ps --filter name=diun --format '{{.Names}}' 2>/dev/null | grep -q diun; then
        local update_count
        update_count=$(docker logs diun --since 24h 2>/dev/null | grep -c "New image" || echo 0)
        if (( update_count > 0 )); then
            warn "${update_count} image update(s) available — run 'evlbox update'"
        else
            ok "All images up to date (checked in last 24h)"
        fi
    else
        info "Diun not running — update checks disabled"
    fi
    echo ""
}

cmd_setup() {
    require_stack
    require_root
    require_file "${STACK_DIR}/setup.sh"

    print_banner
    info "Running stack setup wizard..."
    echo ""

    bash "${STACK_DIR}/setup.sh"
}

cmd_update() {
    require_stack
    require_root
    require_file "$COMPOSE_FILE"
    require_docker
    load_compose_projects

    info "Starting update..."

    # Step 1: backup first
    if [[ -f "${STACK_DIR}/backup.sh" ]]; then
        info "Creating pre-update backup..."
        bash "${STACK_DIR}/backup.sh"
        ok "Backup complete."
    else
        warn "No backup.sh found — skipping pre-update backup."
        if ! confirm "Continue without backup?"; then
            info "Aborted."
            return 0
        fi
    fi

    # Step 2: pull new images (all compose projects)
    info "Pulling latest images..."
    for cf in "${COMPOSE_PROJECTS[@]}"; do
        docker compose -f "$cf" pull
    done

    # Step 3: restart with new images (all compose projects)
    info "Restarting services..."
    for cf in "${COMPOSE_PROJECTS[@]}"; do
        docker compose -f "$cf" up -d --remove-orphans
    done

    ok "Update complete."
    echo ""
    cmd_status
}

cmd_backup() {
    require_stack

    case "${1:-}" in
        list)
            cmd_backup_list
            ;;
        *)
            require_root
            require_file "${STACK_DIR}/backup.sh"
            info "Running backup..."
            bash "${STACK_DIR}/backup.sh"
            ok "Backup complete."
            ;;
    esac
}

cmd_backup_list() {
    if [[ ! -d "$BACKUP_DIR" ]]; then
        warn "No backup directory found at ${BACKUP_DIR}"
        return 0
    fi

    local -a backups=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && backups+=("$line")
    done < <(find "$BACKUP_DIR" -maxdepth 1 -name "*.tar.gz" -printf '%T@ %p\n' 2>/dev/null | sort -rn | cut -d' ' -f2-)

    if [[ ${#backups[@]} -eq 0 ]]; then
        warn "No backups found."
        return 0
    fi

    header "Backups (${#backups[@]} total)"
    echo ""
    printf "  ${BOLD}%-40s %8s  %s${NC}\n" "SNAPSHOT" "SIZE" "DATE"
    echo "  $(printf '%.0s─' {1..65})"
    for f in "${backups[@]}"; do
        local size date name
        size=$(du -h "$f" | cut -f1)
        date=$(stat -c %y "$f" 2>/dev/null | cut -d'.' -f1)
        name=$(basename "$f")
        printf "  %-40s %8s  %s\n" "$name" "$size" "$date"
    done
    echo ""
}

cmd_rollback() {
    require_stack
    require_root
    require_file "$COMPOSE_FILE"
    require_docker
    load_compose_projects

    if [[ ! -d "$BACKUP_DIR" ]]; then
        err "No backup directory found."
        return 1
    fi

    # Gather available backups (newest first)
    local -a backups=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && backups+=("$(basename "$line")")
    done < <(find "$BACKUP_DIR" -maxdepth 1 -name "*.tar.gz" -printf '%T@ %p\n' 2>/dev/null | sort -rn | cut -d' ' -f2-)

    if [[ ${#backups[@]} -eq 0 ]]; then
        err "No backup snapshots found in ${BACKUP_DIR}"
        return 1
    fi

    # Let user choose a backup
    local selected
    if $HAS_GUM; then
        selected=$(printf '%s\n' "${backups[@]}" | gum choose \
            --header "Select backup to restore:" \
            --header.foreground "$BRAND_CYAN" \
            --cursor.foreground "$BRAND_CYAN") || {
            info "No selection made. Aborted."
            return 0
        }
    else
        info "Available backups:"
        echo ""
        local i=1
        for b in "${backups[@]}"; do
            echo "  ${i}) ${b}"
            ((i++))
        done
        echo ""
        read -rp "  Enter number (or 'q' to cancel): " choice
        if [[ "$choice" == "q" || -z "$choice" ]]; then
            info "Aborted."
            return 0
        fi
        if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#backups[@]} )); then
            err "Invalid selection."
            return 1
        fi
        selected="${backups[$((choice-1))]}"
    fi

    local backup_path="${BACKUP_DIR}/${selected}"
    if [[ ! -f "$backup_path" ]]; then
        err "Backup file not found: ${backup_path}"
        return 1
    fi

    warn "This will stop all services and restore from: ${selected}"
    if ! confirm "Proceed with rollback?"; then
        info "Aborted."
        return 0
    fi

    # Stop all compose projects
    info "Stopping services..."
    for cf in "${COMPOSE_PROJECTS[@]}"; do
        docker compose -f "$cf" down
    done

    # Restore
    info "Restoring from ${selected}..."
    tar -xzf "$backup_path" -C /

    # Restart all compose projects
    info "Starting services..."
    for cf in "${COMPOSE_PROJECTS[@]}"; do
        docker compose -f "$cf" up -d
    done

    ok "Rollback complete. Restored from ${selected}."
}

cmd_logs() {
    require_stack
    require_file "$COMPOSE_FILE"
    require_docker
    load_compose_projects

    if [[ -n "${1:-}" ]]; then
        # Try each compose project until we find the service
        local found=false
        for cf in "${COMPOSE_PROJECTS[@]}"; do
            if docker compose -f "$cf" ps --format '{{.Service}}' 2>/dev/null | grep -q "^${1}$"; then
                docker compose -f "$cf" logs -f --tail 50 "$1"
                found=true
                break
            fi
        done
        if ! $found; then
            err "Service '$1' not found in any compose project."
            return 1
        fi
    else
        # Tail all projects
        for cf in "${COMPOSE_PROJECTS[@]}"; do
            docker compose -f "$cf" logs -f --tail 50 &
        done
        # Wait for any background job (user will Ctrl+C)
        wait
    fi
}

cmd_restart() {
    require_stack
    require_root
    require_file "$COMPOSE_FILE"
    require_docker
    load_compose_projects

    if [[ -n "${1:-}" ]]; then
        # Find which project owns this service
        local found=false
        for cf in "${COMPOSE_PROJECTS[@]}"; do
            if docker compose -f "$cf" ps --format '{{.Service}}' 2>/dev/null | grep -q "^${1}$"; then
                info "Restarting $1..."
                docker compose -f "$cf" restart "$1"
                ok "$1 restarted."
                found=true
                break
            fi
        done
        if ! $found; then
            err "Service '$1' not found in any compose project."
            return 1
        fi
    else
        info "Restarting all services..."
        for cf in "${COMPOSE_PROJECTS[@]}"; do
            docker compose -f "$cf" restart
        done
        ok "All services restarted."
    fi
}

cmd_enable() {
    require_stack
    require_root
    require_docker

    local service="${1:-}"
    if [[ -z "$service" ]]; then
        err "Usage: evlbox enable <service>"
        err "Example: evlbox enable forum"
        return 1
    fi

    if [[ -f "${STACK_DIR}/enable.sh" ]]; then
        bash "${STACK_DIR}/enable.sh" "$service"
    else
        err "This stack does not support enable/disable yet."
        err "Re-run 'evlbox setup' to reconfigure services."
        return 1
    fi
}

cmd_disable() {
    require_stack
    require_root
    require_docker

    local service="${1:-}"
    if [[ -z "$service" ]]; then
        err "Usage: evlbox disable <service>"
        err "Example: evlbox disable forum"
        return 1
    fi

    if [[ -f "${STACK_DIR}/disable.sh" ]]; then
        bash "${STACK_DIR}/disable.sh" "$service"
    else
        err "This stack does not support enable/disable yet."
        err "Re-run 'evlbox setup' to reconfigure services."
        return 1
    fi
}

cmd_secure_ssh() {
    require_root

    # Check for SSH keys
    local auth_keys="/root/.ssh/authorized_keys"
    if [[ ! -f "$auth_keys" ]] || [[ ! -s "$auth_keys" ]]; then
        err "No SSH keys found in ${auth_keys}"
        err "Add your public key first, then run this command again."
        echo ""
        err "Example:"
        err "  ssh-copy-id root@$(hostname -I | awk '{print $1}')"
        exit 1
    fi

    local key_count
    key_count=$(grep -c '^ssh-' "$auth_keys" 2>/dev/null || echo 0)
    info "Found ${key_count} SSH key(s) in ${auth_keys}"

    warn "This will DISABLE password-based SSH login."
    warn "Make sure you can log in with your SSH key first."
    echo ""
    if ! confirm "Disable SSH password authentication?"; then
        info "Aborted."
        return 0
    fi

    # Apply sshd hardening — use drop-in dir on Debian 12+ if available
    if [[ -d /etc/ssh/sshd_config.d ]]; then
        cat > /etc/ssh/sshd_config.d/evlbox-hardening.conf << 'SSHD'
# EVLBOX SSH hardening — applied by 'evlbox secure-ssh'
PasswordAuthentication no
PermitRootLogin prohibit-password
SSHD
        info "Created /etc/ssh/sshd_config.d/evlbox-hardening.conf"
    else
        # Legacy: modify sshd_config directly
        local sshd_config="/etc/ssh/sshd_config"
        if grep -q "^PasswordAuthentication" "$sshd_config"; then
            sed -i 's/^PasswordAuthentication.*/PasswordAuthentication no/' "$sshd_config"
        else
            echo "PasswordAuthentication no" >> "$sshd_config"
        fi
        if grep -q "^PermitRootLogin" "$sshd_config"; then
            sed -i 's/^PermitRootLogin.*/PermitRootLogin prohibit-password/' "$sshd_config"
        else
            echo "PermitRootLogin prohibit-password" >> "$sshd_config"
        fi
    fi

    systemctl restart sshd

    ok "SSH hardened. Password authentication disabled."
    ok "Root login: SSH key only."
}

cmd_help() {
    print_banner

    if $HAS_GUM; then
        gum style --foreground "$BRAND_CYAN" --bold "Usage: evlbox <command>"
        echo ""
        gum style --foreground "$BRAND_CYAN" --bold "Commands"
    else
        echo -e "  ${BOLD}Usage:${NC} evlbox <command>"
        echo ""
        echo -e "  ${BOLD}Commands:${NC}"
    fi

    echo "    status          Show services, system info, and backup status"
    echo "    setup           Run the first-time setup wizard"
    echo "    update          Pull latest images and restart (backs up first)"
    echo "    backup          Create a backup snapshot"
    echo "    backup list     List available backup snapshots"
    echo "    rollback        Restore from a backup snapshot"
    echo "    enable <svc>    Enable an optional service"
    echo "    disable <svc>   Disable an optional service"
    echo "    restart [svc]   Restart all services (or one)"
    echo "    logs [svc]      Tail service logs (or one)"
    echo "    secure-ssh      Disable password auth (requires SSH key first)"
    echo "    help            Show this help message"
    echo "    version         Show version"
    echo ""
    echo -e "  ${DIM}Docs: https://evlbox.com/docs${NC}"
    echo ""
}

cmd_version() {
    echo "evlbox ${EVLBOX_VERSION}"
}

# ──────────────────────────────────────────
# Main dispatch
# ──────────────────────────────────────────

# Save original args for error messages
ORIGINAL_ARGS=("$@")

case "${1:-}" in
    status)         cmd_status ;;
    setup)          cmd_setup ;;
    update)         cmd_update ;;
    backup)         shift; cmd_backup "$@" ;;
    rollback)       cmd_rollback ;;
    enable)         shift; cmd_enable "$@" ;;
    disable)        shift; cmd_disable "$@" ;;
    restart)        shift; cmd_restart "$@" ;;
    logs)           shift; cmd_logs "$@" ;;
    secure-ssh)     cmd_secure_ssh ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) cmd_version ;;
    "")             cmd_help ;;
    *)
        err "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
